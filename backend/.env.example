# Copia este archivo como .env y completá los valores

# Generá una clave segura con: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=cambia-esto-en-produccion

ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=480

# Local (SQLite, no requiere nada externo):
DATABASE_URL=sqlite:///./stock_it.db

# Producción (Neon PostgreSQL - pegar la connection string de Neon):
# DATABASE_URL=postgresql://usuario:password@ep-xxx.us-east-2.aws.neon.tech/stock_it?sslmode=require

# Orígenes permitidos (separados por coma, sin espacios)
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000
# Producción (reemplazar con la URL real de Vercel):
# ALLOWED_ORIGINS=https://stock-it-geasa.vercel.app
